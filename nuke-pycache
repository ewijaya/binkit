#!/bin/bash
# nuke-pycache - Recursively delete __pycache__ dirs and .pyc/.pyo files.
#
# Searches from the current directory (or a given path) and removes all
# Python bytecode artifacts. Prints what it deletes.
#
# Prerequisites:
#   - find (coreutils)
#
# Usage:
#   nuke-pycache          # clean current directory
#   nuke-pycache ~/proj   # clean a specific path
#
# Example output:
#   Removed: ./src/__pycache__
#   Removed: ./tests/__pycache__
#   Cleaned 2 __pycache__ dirs, 0 .pyc/.pyo files

set -euo pipefail

target="${1:-.}"

if [ ! -d "$target" ]; then
    echo "Not a directory: $target"
    exit 1
fi

dir_count=0
file_count=0

while IFS= read -r d; do
    echo "Removed: $d"
    rm -rf "$d"
    dir_count=$((dir_count + 1))
done < <(find "$target" -type d -name "__pycache__" 2>/dev/null)

while IFS= read -r f; do
    echo "Removed: $f"
    rm -f "$f"
    file_count=$((file_count + 1))
done < <(find "$target" -type f \( -name "*.pyc" -o -name "*.pyo" \) -not -path "*/__pycache__/*" 2>/dev/null)

echo "Cleaned ${dir_count} __pycache__ dirs, ${file_count} .pyc/.pyo files"
