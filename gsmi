#!/bin/bash
nvidia-smi --query-gpu=utilization.gpu,memory.used,memory.total --format=csv,noheader,nounits | awk -F", " '{printf "GPU: %s%% | VRAM: %s/%s MB\n", $1, $2, $3}'
nvidia-smi --query-compute-apps=pid,process_name,used_memory --format=csv,noheader,nounits | awk -F", " '{printf "  PID %s | %s | %s MB\n", $1, $2, $3}'
