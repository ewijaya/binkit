#!/bin/bash
# codex-usage - Display live OpenAI Codex CLI rate limits from the terminal.
#
# Queries the ChatGPT backend API for real-time 5-hour and weekly usage
# percentages, then renders a compact progress-bar summary.
#
# Prerequisites:
#   - python3
#   - OpenAI Codex CLI installed and logged in (`codex login`)
#     Auth token is read from ~/.codex/auth.json
#
# Usage:
#   codex-usage
#
# Example output:
#   Codex Usage (Plus)
#     5h limit:     [█████░░░░░░░░░░░░░░░] 76% left (resets 18:42)
#     Weekly limit: [█████████████░░░░░░░] 35% left (resets 01:43 on 19 Mar)
#
# Notes:
#   - This is a read-only API call; it does NOT consume any rate limit quota.
#   - If the OAuth token has expired, open Codex once to refresh it.

set -euo pipefail

AUTH_FILE="$HOME/.codex/auth.json"

if [ ! -f "$AUTH_FILE" ]; then
    echo "No Codex auth found. Run 'codex login' first."
    exit 1
fi

python3 - "$AUTH_FILE" <<'PYEOF'
import json, sys, urllib.request
from datetime import datetime, timezone

auth_file = sys.argv[1]
with open(auth_file) as f:
    auth = json.load(f)

token = auth["tokens"]["access_token"]
account_id = auth["tokens"]["account_id"]

url = "https://chatgpt.com/backend-api/codex/usage"
req = urllib.request.Request(url)
req.add_header("Authorization", f"Bearer {token}")
req.add_header("ChatGPT-Account-ID", account_id)
req.add_header("User-Agent", "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/134.0.0.0 Safari/537.36")
req.add_header("Accept", "application/json")
req.add_header("Accept-Language", "en-US,en;q=0.9")
req.add_header("Referer", "https://chatgpt.com/")
req.add_header("Origin", "https://chatgpt.com")
req.add_header("Sec-Fetch-Dest", "empty")
req.add_header("Sec-Fetch-Mode", "cors")
req.add_header("Sec-Fetch-Site", "same-origin")
req.add_header("Sec-Ch-Ua", '"Chromium";v="134", "Not:A-Brand";v="24", "Google Chrome";v="134"')
req.add_header("Sec-Ch-Ua-Mobile", "?0")
req.add_header("Sec-Ch-Ua-Platform", '"Linux"')

try:
    resp = urllib.request.urlopen(req, timeout=10)
    data = json.loads(resp.read().decode())
except urllib.error.HTTPError as e:
    if e.code == 401:
        print("Auth token expired. Open Codex to refresh.")
    else:
        print(f"API error: {e.code}")
    sys.exit(1)
except Exception as e:
    print(f"Failed to fetch usage: {e}")
    sys.exit(1)

rl = data.get("rate_limit", {})
pri = rl.get("primary_window", {})
sec = rl.get("secondary_window", {})
plan = data.get("plan_type", "unknown") or "unknown"

def bar(used_pct, width=20):
    filled = int(round(used_pct / 100.0 * width))
    return "\u2588" * filled + "\u2591" * (width - filled)

def fmt_reset(epoch):
    if not epoch:
        return "unknown"
    dt = datetime.fromtimestamp(epoch, tz=timezone.utc).astimezone()
    return dt.strftime("%H:%M")

def fmt_reset_date(epoch):
    if not epoch:
        return "unknown"
    dt = datetime.fromtimestamp(epoch, tz=timezone.utc).astimezone()
    return dt.strftime("%H:%M on %d %b")

pri_used = pri.get("used_percent", 0)
sec_used = sec.get("used_percent", 0)

print(f"Codex Usage ({plan.capitalize()})")
print(f"  5h limit:     [{bar(pri_used)}] {100-pri_used:.0f}% left (resets {fmt_reset(pri.get('reset_at'))})")
print(f"  Weekly limit: [{bar(sec_used)}] {100-sec_used:.0f}% left (resets {fmt_reset_date(sec.get('reset_at'))})")
PYEOF
